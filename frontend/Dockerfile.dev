# ============================================================
# 前端 Dockerfile（开发环境）
# 核心策略：依赖层与源码层严格分层，仅 Docker 原生分层缓存，无任何额外语法
# ============================================================

# ---------- 构建阶段 ----------
# 接收 DOCKER_REGISTRY 参数作为基础镜像统一前缀
ARG DOCKER_REGISTRY
FROM ${DOCKER_REGISTRY}node:20-alpine AS build

WORKDIR /app

# 设置国内 npm 镜像源（中科大），无需 VPN
RUN npm config set registry https://registry.npmmirror.com/

# ------ 第1层：仅复制依赖清单，package.json/package-lock.json 不变更则不触发重下载 ------
COPY package.json package-lock.json* ./

# package-lock.json 存在时使用 npm ci；旧提交未生成 lockfile 时回退到 npm install
RUN if [ -f package-lock.json ]; then \
      npm ci --no-audit --no-fund; \
    else \
      npm install --no-audit --no-fund; \
    fi

# ------ 第2层：复制源代码，仅业务代码变更时只重跑 build 不重下依赖 ------
COPY . .

RUN npm run build

# ---------- 运行阶段 ----------
ARG DOCKER_REGISTRY
FROM ${DOCKER_REGISTRY}nginx:alpine

ENV TZ=Asia/Shanghai
RUN ln -snf /usr/share/zoneinfo/$TZ /etc/localtime && echo $TZ > /etc/timezone

COPY nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/dist /usr/share/nginx/html

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
