# ============================================================
# 前端 Dockerfile（开发环境）
# 核心策略：依赖层与源码层严格分层，仅 Docker 原生分层缓存，无任何额外语法
# ============================================================

# ---------- 构建阶段 ----------
# 接收 DOCKER_REGISTRY 参数作为基础镜像统一前缀
ARG DOCKER_REGISTRY
FROM ${DOCKER_REGISTRY}node:20-alpine AS build

WORKDIR /app

# 设置国内 npm 镜像源（中科大），无需 VPN
RUN npm config set registry https://mirrors.ustc.edu.cn/npm/ \
    && npm config set disturl https://mirrors.ustc.edu.cn/node/

# ------ 第1层：仅复制依赖清单，package.json 不变更则不触发重下载 ------
COPY package.json ./

# 开发环境使用 npm install（允许根据最新 semver 拉取）
RUN npm install --no-audit --no-fund

# ------ 第2层：复制源代码，仅业务代码变更时只重跑 build 不重下依赖 ------
COPY . .

RUN npm run build

# ---------- 运行阶段 ----------
ARG DOCKER_REGISTRY
FROM ${DOCKER_REGISTRY}nginx:alpine

ENV TZ=Asia/Shanghai
RUN ln -snf /usr/share/zoneinfo/$TZ /etc/localtime && echo $TZ > /etc/timezone

COPY nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/dist /usr/share/nginx/html

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
