# ==============================================================
# 前端 Docker 构建上下文排除文件
# 禁止把本地 node_modules、构建产物、日志、临时文件、IDE 配置打入镜像
# ==============================================================

# --- 依赖目录 ---
node_modules

# --- 构建产物 ---
dist
dist-ssr
build
.output

# --- 日志文件 ---
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- 环境变量 ---
.env
.env.local
.env.*.local

# --- IDE / 编辑器 ---
.idea
.vscode
*.iml
*.iws
*.ipr
.project
.classpath
.settings
*.swp
*.swo
*~

# --- 操作系统 ---
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# --- 临时 / 缓存 ---
*.tmp
*.temp
.cache
.temp
.npm
.eslintcache
.stylelintcache

# --- 测试 / 文档 ---
coverage
*.md
!README.md
test
tests
__tests__
docs

# --- 其他 ---
*.local
Dockerfile
Dockerfile.*
docker-compose*.yml
*.sh
.vite
