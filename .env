# ============================================================
# 组装机专用顶针小件库存登记系统 - 全局环境变量配置
# ============================================================

# -------------------- Docker 镜像仓库统一前缀 --------------------
# 全局所有基础镜像统一使用此前缀，避免直连 DockerHub 拉取失败
# 国内可用的公共加速镜像站（按需修改，留空则使用 DockerHub）：
#   - 阿里云：registry.cn-hangzhou.aliyuncs.com
#   - 网易：hub-mirror.c.163.com
#   - 腾讯：mirror.ccs.tencentyun.com
#   - 中科大镜像：docker.mirrors.ustc.edu.cn
#   - DaoCloud：docker.m.daocloud.io
# 如使用官方库则直接留空
DOCKER_REGISTRY=

# -------------------- 项目标识（容器命名用） --------------------
PROJECT_NAME=small-parts-inventory

# ============================================================
# 端口分配表 - 固定端口，禁止随意修改！
# 避开常用默认端口：80,443,8080,3306,6379,5432,9200 等
# ============================================================

# 前端 Nginx 对外访问端口
FRONTEND_PORT=3008

# 后端 SpringBoot 对外服务端口
BACKEND_PORT=8088

# MySQL 对外映射端口
MYSQL_PORT=3309

# Redis 对外映射端口
REDIS_PORT=6380

# ============================================================
# 数据库配置
# ============================================================
MYSQL_ROOT_PASSWORD=RootPass_2026!
MYSQL_DATABASE=inventory_db
MYSQL_USER=inventory
MYSQL_PASSWORD=InventoryPass_2026!

# ============================================================
# Redis 配置
# ============================================================
REDIS_PASSWORD=RedisPass_2026!
