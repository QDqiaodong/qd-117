<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.inventory.mapper.LineReturnRecordMapper">

    <resultMap id="BaseResultMap" type="com.inventory.entity.LineReturnRecord">
        <id column="id" property="id"/>
        <result column="part_id" property="partId"/>
        <result column="part_model" property="partModel"/>
        <result column="quantity" property="quantity"/>
        <result column="qualified_quantity" property="qualifiedQuantity"/>
        <result column="unqualified_quantity" property="unqualifiedQuantity"/>
        <result column="reusable_status" property="reusableStatus"/>
        <result column="production_line" property="productionLine"/>
        <result column="original_receiver" property="originalReceiver"/>
        <result column="operator" property="operator"/>
        <result column="remark" property="remark"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <select id="selectPageList" resultMap="BaseResultMap">
        SELECT * FROM line_return_record
        <where>
            <if test="startTime != null and startTime != ''">
                AND create_time >= #{startTime}
            </if>
            <if test="endTime != null and endTime != ''">
                AND create_time &lt;= #{endTime}
            </if>
            <if test="partModel != null and partModel != ''">
                AND TRIM(part_model) LIKE CONCAT(TRIM(#{partModel}), '%')
            </if>
            <if test="productionLine != null and productionLine != ''">
                AND production_line = #{productionLine}
            </if>
            <if test="reusableStatus != null and reusableStatus != ''">
                AND reusable_status = #{reusableStatus}
            </if>
        </where>
        ORDER BY create_time DESC, id DESC
    </select>

</mapper>
