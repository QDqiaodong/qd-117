<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.inventory.mapper.ScrapReasonMapper">

    <resultMap id="BaseResultMap" type="com.inventory.entity.ScrapReason">
        <id column="id" property="id"/>
        <result column="reason_name" property="reasonName"/>
        <result column="reason_code" property="reasonCode"/>
        <result column="part_type" property="partType"/>
        <result column="sort" property="sort"/>
        <result column="status" property="status"/>
        <result column="remark" property="remark"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <select id="selectPageList" resultMap="BaseResultMap">
        SELECT * FROM scrap_reason
        <where>
            <if test="reasonName != null and reasonName != ''">
                AND reason_name LIKE CONCAT('%', #{reasonName}, '%')
            </if>
            <if test="partType != null and partType != ''">
                AND part_type = #{partType}
            </if>
            <if test="status != null">
                AND status = #{status}
            </if>
        </where>
        ORDER BY sort ASC, create_time DESC
    </select>

</mapper>
