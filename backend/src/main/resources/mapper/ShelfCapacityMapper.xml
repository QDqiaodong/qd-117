<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.inventory.mapper.ShelfCapacityMapper">

    <resultMap id="BaseResultMap" type="com.inventory.entity.ShelfCapacity">
        <id column="id" property="id"/>
        <result column="shelf_no" property="shelfNo"/>
        <result column="max_pin_boxes" property="maxPinBoxes"/>
        <result column="max_shim_packs" property="maxShimPacks"/>
        <result column="current_pin_boxes" property="currentPinBoxes"/>
        <result column="current_shim_packs" property="currentShimPacks"/>
        <result column="remark" property="remark"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <select id="selectPageList" resultMap="BaseResultMap">
        SELECT * FROM shelf_capacity
        <where>
            <if test="shelfNo != null and shelfNo != ''">
                AND shelf_no LIKE CONCAT('%', #{shelfNo}, '%')
            </if>
        </where>
        ORDER BY create_time DESC
    </select>

</mapper>
